---
import '../styles/theme.css';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: string;
  dir?: "ltr" | "rtl";
}

const { title, description, ogImage, lang = "en", dir = "ltr" } = Astro.props;
---


<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title} -h</title>

    <meta
      name="description"
      content={description || 'A retro-arcade blog'}
    />

    <!-- Canonical -->
    <link rel="canonical" href={Astro.url.href} />


    <!-- fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link
      href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=VT323&display=swap" rel="stylesheet">


    <!-- Open Graph -->
    <meta property="og:title" content={`${title} • human readable`} />
    <meta
      property="og:description"
      content={description || 'A retro-arcade blog'}
    />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="human readable" />
    <meta property="og:locale" content="en_US" />

    {ogImage && (
      <>
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:secure_url" content={ogImage} />
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={title} />
      </>
    )}

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} • human readable`} />
    <meta
      name="twitter:description"
      content={description || 'A retro-arcade blog'}
    />

    {ogImage && (
      <meta name="twitter:image" content={ogImage} />
    )}

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />



    </head>
    <body>

      <header class="site-header">
        <div class="container">
          <nav class="site-nav">
            <a href={import.meta.env.BASE_URL} class="site-title">
              <span class="bracket">[</span>
              <span class="title-text">-h</span>
              <span class="bracket">]</span>
            </a>
            <ul class="nav-links">
              <li><a href={import.meta.env.BASE_URL}>home</a></li>
              <li><a href={`${import.meta.env.BASE_URL}#posts`}>posts</a></li>
              <li><a href={import.meta.env.BASE_URL + 'about'}>about</a></li>

            </ul>
          </nav>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <Footer 
        github="https://github.com/cs-astronaut"
        linkedin="https://www.linkedin.com/in/amin-farahani-8a6511263/"
        telegram="https://t.me/Astro_Terminal"
      />
    </body>
  </html>

  <style>

    /* Layout.astro */
    html, body {
      height: 100%;
    }

    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    main {
      flex: 1 0 auto; /* fills remaining space, no overshoot */
    }






    .site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: linear-gradient(
        180deg,
        rgba(26, 27, 38, 0.95) 0%,
        rgba(26, 27, 38, 0.85) 100%
      );
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(122, 162, 247, 0.1);
      padding: 1.2rem 0;
      margin-bottom: 3rem;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .site-nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 3rem;
    }

    .site-title {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.7rem;
      font-weight: 100;
      letter-spacing: 2px;
      text-decoration: none;
      color: var(--color-primary);
      transition: all 0.3s ease;
      flex-shrink: 0;
      text-transform: lowercase;
      text-decoration: none;

    }

    .site-title:hover {
      color: var(--color-accent);
      text-shadow: 0 0 10px rgba(187, 154, 247, 0.5);
    }

    .title-text {
      text-transform: lowercase;
      font-family: "Workbench";
    }

    .bracket {
      color: var(--color-accent-warm);
      font-weight: 900;
      opacity: 0.8;
      font-family: "Workbench";
    }

    .nav-links {
      display: flex;
      list-style: none;
      margin: 0;
      padding: 0;
      gap: 0.5rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .nav-links a {
      display: inline-block;
      padding: 0.6rem 1.2rem;
      font-size: 0.95rem;
      color: var(--color-text-dim);
      text-decoration: none;
      text-transform: lowercase;
      letter-spacing: 1px;
      border-radius: 4px;
      transition: all 0.25s ease;
      position: relative;
      border: 1px solid transparent;
    }

    .nav-links a:hover {
      color: var(--color-primary);
      background-color: rgba(122, 162, 247, 0.08);
      border-color: rgba(122, 162, 247, 0.3);
      box-shadow: 0 0 12px rgba(122, 162, 247, 0.2);
    }

    .nav-links a::before {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      width: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
      transform: translateX(-50%);
      transition: width 0.3s ease;
    }

    .nav-links a:hover::before {
      width: 100%;
    }

    /* main { */
    /*   min-height: calc(100vh - 300px); */
    /* } */

    @media (max-width: 768px) {
      .site-nav {
        gap: 1.5rem;
      }

      .site-title {
        font-size: 1.3rem;
      }

      .nav-links {
        gap: 0.25rem;
      }

      .nav-links a {
        padding: 0.5rem 0.8rem;
        font-size: 0.85rem;
      }
    }

    @media (max-width: 640px) {
      .site-header {
        padding: 0.75rem 0;
        margin-bottom: 2rem;
      }

      .site-nav {
        gap: 1rem;
        flex-wrap: nowrap;
      }

      .site-title {
        font-size: 0.95rem;
        gap: 0.3rem;
      }

      .nav-links {
        width: 100%;
        gap: 0.2rem;
        order: 3;
      }

      .nav-links a {
        padding: 0.4rem 0.6rem;
        font-size: 0.8rem;
      }
    }





  </style>
