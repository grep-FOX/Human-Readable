---
import '../styles/theme.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title} • human readable</title>

    <meta
      name="description"
      content={description || 'A retro-arcade blog'}
    />

    <!-- Canonical -->
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} • human readable`} />
    <meta
      property="og:description"
      content={description || 'A retro-arcade blog'}
    />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="human readable" />
    <meta property="og:locale" content="en_US" />

    {ogImage && (
      <>
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:secure_url" content={ogImage} />
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={title} />
      </>
    )}

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} • human readable`} />
    <meta
      name="twitter:description"
      content={description || 'A retro-arcade blog'}
    />

    {ogImage && (
      <meta name="twitter:image" content={ogImage} />
    )}

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />



    </head>
    <body>
      <header class="site-header">
        <div class="container">
          <nav class="site-nav">
            <a href={import.meta.env.BASE_URL} class="site-title">
              <span class="bracket">[</span>
              human readable
              <span class="bracket">]</span>
            </a>
            <ul class="nav-links">
              <li><a href={import.meta.env.BASE_URL}>home</a></li>
              <li><a href={`${import.meta.env.BASE_URL}#posts`}>posts</a></li>
            </ul>
          </nav>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div class="container">
          <p class="text-dim">
            ~ human readable ~ made with <span class="accent">♠</span> ~
          </p>
        </div>
      </footer>
    </body>
  </html>

  <style>
    .site-header {
      border-bottom: 2px solid var(--color-surface-light);
      padding: 2rem 0;
      margin-bottom: 3rem;
    }

    .site-nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .site-title {
      font-size: 1.8rem;
      font-weight: bold;
      color: var(--color-primary-bright);
      border: none;
      text-shadow: var(--glow-bright);
      text-transform: lowercase;
      letter-spacing: 2px;
    }

    .bracket {
      color: var(--color-accent);
      margin: 0 0.5rem;
    }

    .nav-links {
      display: flex;
      list-style: none;
      gap: 2rem;
      margin: 0;
    }

    .nav-links a {
      font-size: 0.95rem;
      text-transform: lowercase;
      letter-spacing: 0.5px;
    }

    .site-footer {
      border-top: 2px solid var(--color-surface-light);
      padding: 2rem 0;
      margin-top: 4rem;
      text-align: center;
    }

    main {
      min-height: calc(100vh - 300px);
    }

    @media (max-width: 640px) {
      .site-nav {
        flex-direction: column;
        gap: 1rem;
      }

      .nav-links {
        gap: 1rem;
      }

      .site-title {
        font-size: 1.4rem;
      }
    }
  </style>
