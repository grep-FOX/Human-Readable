---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import CRTBio from "../components/CRTBio/CRTBio.astro";

const images = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/slideshow/*.{jpg,jpeg,png,webp}",
  { eager: true }
);

const slideImages = Object.values(images)
  .map((m) => m.default)
  .sort();

const randomImage =
  slideImages[Math.floor(Math.random() * slideImages.length)];
---

<Layout title="About — human readable">

    <Image
        src={randomImage}
        alt=""
        loading="eager"
        fetchpriority="high"
        class="background"
    />

    <div class="background-overlay"></div>
    <section class="about">
        <div class="terminal-container">
            <CRTBio />
        </div>
    </section>

</Layout>


<style>
:root {
  --terminal-max-width: 960px;
  --page-padding: clamp(1rem, 4vw, 3rem);
}

/* ==========================================
   BACKGROUND
========================================== */

.background {
  position: fixed;
  inset: 0;

  width: 100%;
  height: 100%;

  object-fit: cover;

  z-index: -2;

  transform: scale(1.08);

  filter:
    brightness(0.28)
    contrast(1.08)
    saturate(0.65);
}

.background-overlay {
  position: fixed;
  inset: 0;

  z-index: -1;
  pointer-events: none;

  background:
    radial-gradient(
      circle at center,
      rgba(26, 27, 38, 0.08) 0%,
      rgba(26, 27, 38, 0.45) 45%,
      rgba(26, 27, 38, 0.92) 100%
    );
}

/* ==========================================
   PAGE
========================================== */

.about {
  position: relative;
  z-index: 1;

  display: flex;
  justify-content: center;

  padding:
    1rem
    var(--page-padding)
    3rem;
}

/* ==========================================
   TERMINAL
========================================== */

.terminal-container {
  position: relative;

  width: min(100%, var(--terminal-max-width));
  margin-inline: auto;
}

/* Ambient glow */

.terminal-container::before {
  content: "";

  position: absolute;
  inset: -80px;

  z-index: -1;

  background:
    radial-gradient(
      circle,
      rgba(122, 162, 247, 0.08),
      transparent 70%
    );

  filter: blur(80px);
}

/* ==========================================
   LARGE SCREENS
========================================== */

@media (min-width: 1600px) {

  .terminal-container {
    max-width: 1100px;
  }

}

/* ==========================================
   TABLETS
========================================== */

@media (max-width: 900px) {

  .about {
    padding:
      1rem
      1.5rem
      2rem;
  }

}

/* ==========================================
   MOBILE
========================================== */

@media (max-width: 640px) {

  .background {
    transform: scale(1.12);
    object-position: center top;
  }

  .about {
    padding:
      1rem
      1rem
      2rem;
  }

  .terminal-container::before {
    inset: -40px;
    filter: blur(50px);
  }

}
</style>
